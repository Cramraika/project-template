{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":rebaseStalePrs",
    "group:allNonMajor",
    "mergeConfidence:all-badges"
  ],
  "timezone": "Asia/Calcutta",
  "schedule": ["before 5am on monday"],
  "labels": ["dependencies", "renovate"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "minimumReleaseAge": "3 days",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"],
    "schedule": [],
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Auto-merge ALL patch updates (production + dev deps)",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true
    },
    {
      "description": "Auto-merge minor updates for dev dependencies only",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true
    },
    {
      "description": "Production minor updates: PR required (no automerge)",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "labels": ["dependencies", "minor-update", "needs-review"]
    },
    {
      "description": "Group Docker base image updates",
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker base images"
    },
    {
      "description": "Group + pin GitHub Actions to digests (supply-chain hardening)",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true
    },
    {
      "description": "Major updates require explicit review",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update", "needs-review"],
      "automerge": false,
      "automergeType": "pr"
    },
    {
      "description": "Group Lockfile maintenance",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "automerge": true,
      "automergeType": "branch",
      "schedule": ["before 5am on monday"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "rebaseWhen": "behind-base-branch",
  "ignoreDeps": []
}
